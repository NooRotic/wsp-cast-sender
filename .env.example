# Copy this file to .env and fill in your values.
# NEXT_PUBLIC_* values are inlined at build time and visible in the browser bundle.
# Everything else is server/CI-only and should NEVER be committed — use GitHub Secrets.

# ── Developer / Portfolio ──────────────────────────────────────────────────────
NEXT_PUBLIC_DEVELOPER_NAME="Your Name"
NEXT_PUBLIC_DEVELOPER_TITLE="Your Title"
NEXT_PUBLIC_PORTFOLIO_TITLE="Your Name - Portfolio"
NEXT_PUBLIC_PORTFOLIO_DESCRIPTION="Showcasing my work"

# ── Contact (shown in UI) ──────────────────────────────────────────────────────
NEXT_PUBLIC_EMAIL="you@example.com"
NEXT_PUBLIC_LINKEDIN="linkedin.com/in/yourprofile"
NEXT_PUBLIC_GITHUB="github.com/yourprofile"
NEXT_PUBLIC_PHONE="+1 (555) 000-0000"

# ── Site URL (used for metadata base URL in layout.tsx) ───────────────────────
# Production:  https://walter.pollardjr.com
# Staging:     https://staging.walter.pollardjr.com  ← set via GitHub Secret
NEXT_PUBLIC_BASE_URL="https://yoursite.com"

# ── Google Cast ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CAST_APP_ID="YOUR_CAST_APP_ID"
NEXT_PUBLIC_CAST_NAMESPACE="urn:x-cast:com.yournamespace"

# ── IONOS Deploy Now (CI/server-side only — store in GitHub Secrets, not here) ─
# WEB_HOST_API_PUBLIC_PREFIX=
# WEB_HOST_API_SECRET=
